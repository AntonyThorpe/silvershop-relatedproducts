{
    "name": "antonythorpe/silvershop-relatedproducts",
    "description": "SilverShop submodule which allows you to specify related products for any Product",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "SilverStripe",
        "SilverShop",
        "related products"
    ],
    "require": {
        "silvershop/core": "^6.0.0",
        "silverstripe/cms": "^6.2.0"
    },
    "require-dev": {
        "cambis/silverstan": "^2.1.8",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "AntonyThorpe\\SilverShopRelatedProducts\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "3.*-dev"
        }
    },
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true
}
